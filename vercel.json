{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "nodeVersion": "18.x",
  "env": {
    "NODE_ENV": {
      "value": "production"
    }
  },
  "envPrefix": "NEXT_PUBLIC_",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/",
      "permanent": false
    }
  ],
  "functions": {
    "api/**/*.{ts,tsx}": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "crons": []
}
