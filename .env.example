# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Authentication
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@golfcharity.app

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key-here

# Database Storage
SUPABASE_STORAGE_BUCKET=golf-charity-uploads

# Environment
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Instructions for setup:
# 1. Copy this file to .env.local
# 2. Replace all placeholder values with actual credentials
# 3. Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# 4. Get Supabase keys from: https://app.supabase.com/[project]/settings/api
# 5. Get Stripe keys from: https://dashboard.stripe.com/apikeys
# 6. Get Resend key from: https://resend.com/api-keys
# 7. Never commit .env.local to version control
